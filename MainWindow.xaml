<Window x:Name="MainWindow1" x:Class="TimeTask.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeTask"
        mc:Ignorable="d" AllowsTransparency="True" WindowStyle="None" 
        Title="{local:Loc Key=Window_Main_Title}" Width="810" Height="720" MouseLeftButtonDown="Window_MouseLeftButtonDown" Loaded="Window_Loaded"
        LocationChanged="location_Save"
        Background="Transparent" ShowInTaskbar="False">
    <Window.Resources>
        <local:TaskWithReminderIndicatorConverter x:Key="TaskReminderConverter"/>
        <!-- Converter to check if a value is greater than a parameter -->
        <local:IsGreaterThanConverter x:Key="IsGreaterThanConverter" />
        <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibilityConverter" />
        <Style TargetType="DataGridRow" x:Key="StickyNoteRowStyle">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridRow_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="PreviewMouseMove" Handler="DataGridRow_PreviewMouseMove"/>
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="DataGridRow_PreviewMouseLeftButtonUp"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="DGR_Border" CornerRadius="5" Background="#FFFFE0" Padding="5" Margin="3,5,3,5" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" Color="Gray" Opacity="0.5" BlurRadius="3"/>
                            </Border.Effect>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver"/>
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="DGR_Border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FFFBFFAA" Duration="0"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="SelectedUnfocused">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="DGR_Border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FFFDFFAA" Duration="0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <SelectiveScrollingGrid Grid.Column="0">
                                    <SelectiveScrollingGrid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </SelectiveScrollingGrid.ColumnDefinitions>
                                    <SelectiveScrollingGrid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </SelectiveScrollingGrid.RowDefinitions>
                                    <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1" SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Visibility="{TemplateBinding DetailsVisibility}"/>
                                    <DataGridRowHeader Grid.RowSpan="2" SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical" Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>
                                </SelectiveScrollingGrid>
                                <Button x:Name="PART_ReminderButton" Grid.Column="1" Content="⏰" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Click="EditReminderTime_Click" Background="Transparent" BorderBrush="{x:Null}" FontWeight="Bold" Foreground="Gray" ToolTip="{local:Loc Key=Tooltip_EditReminderTime}" Visibility="{Binding Task, Converter={StaticResource NonEmptyStringToVisibilityConverter}}"/>
                                <Button x:Name="PART_DecomposeButton" Grid.Column="2" Content="🧩" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Click="QuickDecomposeTask_Click" Background="Transparent" BorderBrush="{x:Null}" FontWeight="Bold" Foreground="Gray" ToolTip="{local:Loc Key=Tooltip_QuickDecompose}" Visibility="{Binding Task, Converter={StaticResource NonEmptyStringToVisibilityConverter}}"/>
                                <Button x:Name="PART_ThinkingButton" Grid.Column="3" Content="🧠" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Click="ToolQuickAction_Click" Background="Transparent" BorderBrush="{x:Null}" FontWeight="Bold" Foreground="Gray" ToolTip="{local:Loc Key=Tooltip_ThinkingTools}" Visibility="{Binding Task, Converter={StaticResource NonEmptyStringToVisibilityConverter}}"/>
                                <Button x:Name="PART_DeleteButton" Grid.Column="4" Content="X" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" Click="DeleteTaskRow_Click" Background="Transparent" BorderBrush="{x:Null}" FontWeight="Bold" Foreground="Gray" Visibility="{Binding Task, Converter={StaticResource NonEmptyStringToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding InactiveWarningCount}" Value="0">
                                <!-- Default background is #FFFFE0 set on DGR_Border -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding InactiveWarningCount}" Value="1">
                                <Setter TargetName="DGR_Border" Property="Background" Value="#FFFFCC" /> <!-- Slightly more yellow/orange for 1 warning -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding InactiveWarningCount}" Value="2">
                                <Setter TargetName="DGR_Border" Property="Background" Value="#FFFFB3" /> <!-- More orange for 2 warnings -->
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding InactiveWarningCount, Converter={StaticResource IsGreaterThanConverter}, ConverterParameter=2}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="DGR_Border" Property="Background" Value="#FFFAA0A0" /> <!-- LightCoral/Reddish for 3+ warnings -->
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid x:Name="TaskGrid" Width="780" Height="720">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Settings Button -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="100" Margin="0,10,10,0">
            <Button x:Name="VoiceStatusButton"
                    Width="Auto"
                    Height="30"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Padding="10,0"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    ToolTip="{local:Loc Key=Tooltip_VoiceStatus}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DDDDDD"/>
                        <Setter Property="BorderBrush" Value="#AAAAAA"/>
                        <Setter Property="Foreground" Value="#888888"/>
                    </Style>
                </Button.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VoiceStatusIcon"
                               Text="👂"
                               Grid.Column="0"
                               Margin="0,0,5,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="VoiceStatusScale" ScaleX="1" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="VoiceStatusText"
                               Grid.Column="1"
                               Text="{local:Loc Key=Voice_TextUnknown}"
                               VerticalAlignment="Center"
                               Foreground="#666666"/>
                    <Ellipse x:Name="VoiceStatusDot"
                             Grid.Column="2"
                             Width="7"
                             Height="7"
                             Fill="#888888"
                             VerticalAlignment="Center"
                             Margin="6,0,0,0"/>
                </Grid>
            </Button>

            <!-- Active Long-Term Goal Display -->
            <Button x:Name="ActiveLongTermGoalDisplay"
                    Visibility="Collapsed"
                    Width="Auto"
                    Height="30"
                    Margin="0,0,10,0"
                    Padding="10,0"
                    FontSize="14"
                    ToolTip="{local:Loc Key=Tooltip_ActiveLongTermGoal}"
                    Click="ActiveLongTermGoalDisplay_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DDDDDD"/>
                        <Setter Property="BorderBrush" Value="#AAAAAA"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ActiveLongTermGoalName" Text="{local:Loc Key=ActiveLongGoal_DefaultName}" VerticalAlignment="Center"/>
                    <Border Background="Red" CornerRadius="8" Margin="5,0,0,0" Padding="5,2" VerticalAlignment="Center">
                        <TextBlock x:Name="LongTermGoalBadge" Text="0" Foreground="White" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Button>

            <Button x:Name="SettingsButton"
                    Content="⚙"
                    Width="30"
                    Height="30"
                    FontSize="16"
                    FontWeight="Bold"
                    ToolTip="{local:Loc Key=Tooltip_OpenSettings}"
                    Click="SettingsButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DDDDDD"/>
                        <Setter Property="BorderBrush" Value="#AAAAAA"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="DraftsButton"
                    Width="30"
                    Height="30"
                    FontSize="16"
                    FontWeight="Bold"
                    ToolTip="{local:Loc Key=Tooltip_ViewDrafts}"
                    Click="DraftsButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DDDDDD"/>
                        <Setter Property="BorderBrush" Value="#AAAAAA"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <TextBlock Text="📋" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border x:Name="DraftBadge"
                            Background="#E53935"
                            CornerRadius="8"
                            MinWidth="16"
                            Height="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-4,-4,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="DraftBadgeText"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Padding="4,0"/>
                    </Border>
                </Grid>
            </Button>

        </StackPanel>

        <Border x:Name="SystemPanelRoot" Grid.Row="0" Grid.ColumnSpan="2" Background="#F7F1D8" CornerRadius="10" Padding="12" Margin="5,48,5,0" BorderBrush="#E0CC88" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid x:Name="SystemPanelTopGrid" Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SystemSummaryColumn" Width="2.4*"/>
                        <ColumnDefinition x:Name="SystemSkillColumn" Width="1.4*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="SystemSummarySection" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="{local:Loc Key=SystemPanel_Title}" FontSize="16" FontWeight="Bold" Foreground="#6B4A00"/>
                        <TextBlock x:Name="SystemStageText" Text="{local:Loc Key=SystemPanel_StageDefault}" Margin="0,4,0,0" FontWeight="SemiBold" Foreground="#4E4E4E" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="SystemNarrativeText" Text="{local:Loc Key=SystemPanel_NarrativeDefault}" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#666666" MaxHeight="36"/>
                        <WrapPanel Margin="0,8,0,0">
                            <Border Background="#FFF8E7" BorderBrush="#E7D08E" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,8,6">
                                <TextBlock x:Name="SystemLevelText" Text="Lv.1" FontWeight="Bold" Foreground="#7A4E00"/>
                            </Border>
                            <Border Background="#FFF8E7" BorderBrush="#E7D08E" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,8,6">
                                <TextBlock x:Name="SystemXpText" Foreground="#6E6E6E"/>
                            </Border>
                            <Border Background="#EEF5FF" BorderBrush="#C7DAF5" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,8,6">
                                <TextBlock x:Name="SystemQuestText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                            </Border>
                            <Border Background="#EEF8EE" BorderBrush="#CBE3CB" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,0,6">
                                <TextBlock x:Name="SystemSkillText" Foreground="#4E6A3C" TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" x:Name="SystemSkillTreeSection">
                        <TextBlock Text="{local:Loc Key=SystemPanel_SkillTreeTitle}" FontWeight="Bold" Foreground="#7A4E00" Margin="0,0,0,6"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Border x:Name="SkillTreeCard1" Background="#FFF4D6" BorderBrush="#E9D39A" BorderThickness="1" CornerRadius="16" Padding="8,6" Margin="0,0,6,6" Cursor="Hand" MouseLeftButtonUp="SkillTreeCard_Click">
                                <StackPanel>
                                    <TextBlock x:Name="SkillTreeName1" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SkillTreeLevel1" Margin="0,2,0,0" Foreground="#6E6E6E" FontSize="11"/>
                                    <TextBlock x:Name="SkillTreeMeta1" Margin="0,1,0,0" Foreground="#7A6A44" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="10"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="SkillTreeCard2" Background="#EEF5FF" BorderBrush="#C7DAF5" BorderThickness="1" CornerRadius="16" Padding="8,6" Margin="0,0,0,6" Cursor="Hand" MouseLeftButtonUp="SkillTreeCard_Click">
                                <StackPanel>
                                    <TextBlock x:Name="SkillTreeName2" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SkillTreeLevel2" Margin="0,2,0,0" Foreground="#6E6E6E" FontSize="11"/>
                                    <TextBlock x:Name="SkillTreeMeta2" Margin="0,1,0,0" Foreground="#4E6582" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="10"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="SkillTreeCard3" Background="#EEF8EE" BorderBrush="#CBE3CB" BorderThickness="1" CornerRadius="16" Padding="8,6" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonUp="SkillTreeCard_Click">
                                <StackPanel>
                                    <TextBlock x:Name="SkillTreeName3" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SkillTreeLevel3" Margin="0,2,0,0" Foreground="#6E6E6E" FontSize="11"/>
                                    <TextBlock x:Name="SkillTreeMeta3" Margin="0,1,0,0" Foreground="#54704C" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="10"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="SkillTreeCard4" Background="#F4F0FA" BorderBrush="#DDD0F0" BorderThickness="1" CornerRadius="16" Padding="8,6" Cursor="Hand" MouseLeftButtonUp="SkillTreeCard_Click">
                                <StackPanel>
                                    <TextBlock x:Name="SkillTreeName4" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SkillTreeLevel4" Margin="0,2,0,0" Foreground="#6E6E6E" FontSize="11"/>
                                    <TextBlock x:Name="SkillTreeMeta4" Margin="0,1,0,0" Foreground="#6A5883" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="10"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <Button x:Name="SystemPanelToggleButton"
                            Grid.Column="2"
                            Width="64"
                            Height="28"
                            Margin="10,0,0,0"
                            VerticalAlignment="Top"
                            Content="{local:Loc Key=SystemPanel_ButtonExpand}"
                            Click="SystemPanelToggleButton_Click"/>
                </Grid>

                <Border x:Name="SystemTickerBanner" Grid.Row="1" Background="#FFF8E7" BorderBrush="#E7D08E" BorderThickness="1" CornerRadius="16" Padding="10,6" Margin="0,0,0,8">
                    <TextBlock x:Name="SystemTickerText"
                               Text="{local:Loc Key=SystemPanel_TickerDefault}"
                               TextWrapping="Wrap"
                               Foreground="#6A5A33"/>
                </Border>

                <Grid x:Name="FocusBoardDetailSection" Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#FFF8E7" CornerRadius="8" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Key=FocusBoard_PrimaryTitle}" FontWeight="Bold" Foreground="#7A4E00" Margin="0,0,0,4"/>
                        <TextBlock x:Name="PrimaryFocusTaskText" Text="{local:Loc Key=FocusBoard_Empty}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,3"/>
                        <TextBlock x:Name="PrimaryFocusMetaText" TextWrapping="Wrap" Foreground="#6E6E6E" Margin="0,0,0,8"/>
                        <Button x:Name="PrimaryFocusButton" Content="{local:Loc Key=FocusBoard_ButtonLocate}" Width="88" HorizontalAlignment="Left" Click="PrimaryFocusButton_Click" IsEnabled="False"/>
                    </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#EEF7FF" CornerRadius="8" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Key=FocusBoard_ReminderTitle}" FontWeight="Bold" Foreground="#165A8A" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ReminderFocusTaskText" Text="{local:Loc Key=FocusBoard_Empty}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,3"/>
                        <TextBlock x:Name="ReminderFocusMetaText" TextWrapping="Wrap" Foreground="#6E6E6E" Margin="0,0,0,8"/>
                        <Button x:Name="ReminderFocusButton" Content="{local:Loc Key=FocusBoard_ButtonLocate}" Width="88" HorizontalAlignment="Left" Click="ReminderFocusButton_Click" IsEnabled="False"/>
                    </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#F2F8EE" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Key=FocusBoard_StuckTitle}" FontWeight="Bold" Foreground="#3E6B2A" Margin="0,0,0,4"/>
                        <TextBlock x:Name="StuckFocusTaskText" Text="{local:Loc Key=FocusBoard_Empty}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,3"/>
                        <TextBlock x:Name="StuckFocusMetaText" TextWrapping="Wrap" Foreground="#6E6E6E" Margin="0,0,0,8"/>
                        <Button x:Name="StuckFocusButton" Content="{local:Loc Key=FocusBoard_ButtonLocate}" Width="88" HorizontalAlignment="Left" Click="StuckFocusButton_Click" IsEnabled="False"/>
                    </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Quadrant 1: Important & Urgent -->
        <Border Grid.Row="1" Grid.Column="0" Background="#33FFDADA" CornerRadius="5" Padding="5" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                    <Label Content="{local:Loc Key=Quadrant_ImportantUrgent}" HorizontalAlignment="Left" Margin="5,0,0,0" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="White" />
                    <Border Background="#55FFFFFF" CornerRadius="10" Margin="8,0,0,0" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock x:Name="Quadrant1CountText" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Button x:Name="AddUrgentImportantTaskButton" Content="+" Tag="0" Click="AddQuickTask_Click" Width="25" Height="25" FontSize="14" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Background="#AAFFDADA" BorderBrush="#88FFDADA" Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12.5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
                <DataGrid Grid.Row="1" x:Name="task1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SelectionChanged="task1_SelectionChanged" Background="Transparent" HeadersVisibility="None" RowStyle="{StaticResource StickyNoteRowStyle}" AutoGenerateColumns="False" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" AllowDrop="True" DragEnter="Task_DragEnter" DragOver="Task_DragOver" Drop="Quadrant_Drop" CellEditEnding="DataGrid_CellEditEnding" MouseDoubleClick="DataGrid_MouseDoubleClick_AddTask" PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown_BeginEdit" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{local:Loc Key=Task_Header}" Width="*" MaxWidth="325">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock TextWrapping="Wrap">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource TaskReminderConverter}">
                                                <Binding Path="Task"/>
                                                <Binding Path="ReminderTime"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Task, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Quadrant 2: Important & Not Urgent -->
        <Border Grid.Row="1" Grid.Column="1" Background="#33D4E8FF" CornerRadius="5" Padding="5" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="{local:Loc Key=Quadrant_ImportantNotUrgent}" HorizontalAlignment="Left" Margin="5,0,0,0" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="White" />
                        <Border Background="#55FFFFFF" CornerRadius="10" Margin="8,0,0,0" Padding="6,1" VerticalAlignment="Center">
                            <TextBlock x:Name="Quadrant2CountText" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Border>
